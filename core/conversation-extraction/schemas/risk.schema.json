{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdlc-skill-pack/core/conversation-extraction/schemas/risk.schema.json",
  "title": "Risk Extraction",
  "type": "object",
  "required": ["suggestion_id", "statement", "impact", "likelihood", "mitigation", "source_message_ids"],
  "properties": {
    "suggestion_id": {"type": "string"},
    "statement": {"type": "string"},
    "impact": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "likelihood": {"type": "string", "enum": ["rare", "possible", "likely", "almost_certain"]},
    "mitigation": {"type": "string"},
    "source_message_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": false
}
