{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdlc-skill-pack/core/conversation-extraction/schemas/decision.schema.json",
  "title": "Decision Extraction",
  "type": "object",
  "required": ["suggestion_id", "question", "decision", "rationale", "source_message_ids"],
  "properties": {
    "suggestion_id": {"type": "string"},
    "question": {"type": "string"},
    "decision": {"type": "string"},
    "rationale": {"type": "string"},
    "alternatives_considered": {"type": "array", "items": {"type": "string"}},
    "source_message_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": false
}
