{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.dev/schemas/approval-decision.model.json",
  "title": "Business Approval Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_id",
    "decision",
    "decision_timestamp",
    "actor",
    "justification",
    "evidence"
  ],
  "properties": {
    "approval_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "reject",
        "request_more_info"
      ]
    },
    "decision_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "required": [
        "actor_id",
        "actor_type"
      ],
      "properties": {
        "actor_id": {
          "type": "string"
        },
        "actor_type": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "justification": {
      "type": "string"
    },
    "evidence": {
      "type": "object",
      "required": [
        "evidence_pack_id",
        "artifacts",
        "lineage",
        "integrity"
      ],
      "properties": {
        "evidence_pack_id": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "artifact_id",
              "artifact_type",
              "uri",
              "hash"
            ],
            "properties": {
              "artifact_id": {
                "type": "string"
              },
              "artifact_type": {
                "type": "string"
              },
              "uri": {
                "type": "string"
              },
              "hash": {
                "type": "string"
              },
              "captured_at": {
                "type": "string",
                "format": "date-time"
              }
            },
            "additionalProperties": false
          }
        },
        "lineage": {
          "type": "object",
          "required": [
            "correlation_id",
            "causation_id"
          ],
          "properties": {
            "correlation_id": {
              "type": "string"
            },
            "causation_id": {
              "type": "string"
            },
            "parent_event_ids": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "integrity": {
          "type": "object",
          "required": [
            "signature",
            "algorithm"
          ],
          "properties": {
            "signature": {
              "type": "string"
            },
            "algorithm": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
