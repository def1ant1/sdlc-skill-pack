{
  "type": "skill",
  "domain": "business-operations",
  "version": "9.0.0",
  "owner": "Apotheon",
  "maturity": "beta",
  "dependencies": [
    "core/policy-engine",
    "core/business-approval-gateway"
  ],
  "required_context": [
    "tenant_profile",
    "canonical_entities",
    "policy_profile"
  ],
  "optional_context": [
    "historical_events",
    "benchmark_data"
  ],
  "input_contract": {
    "format": "canonical-entity-event-bundle",
    "schema_refs": [
      "core/canonical-entity-model/README.md",
      "core/business-event-model/README.md",
      "schemas/entities/lead.schema.json",
      "schemas/entities/customer.schema.json",
      "schemas/entities/service.schema.json",
      "schemas/entities/workflow.schema.json",
      "schemas/entities/decision.schema.json",
      "schemas/entities/task.schema.json",
      "schemas/events/approval_requested.schema.json",
      "schemas/events/approval_decided.schema.json",
      "schemas/events/workflow_completed.schema.json",
      "schemas/events/business_policy_violation.schema.json",
      "schemas/entities/opportunity.schema.json",
      "schemas/entities/campaign.schema.json",
      "schemas/entities/ticket.schema.json"
    ]
  },
  "output_contract": {
    "format": "canonical-entity-event-bundle",
    "schema_refs": [
      "core/canonical-entity-model/README.md",
      "core/business-event-model/README.md",
      "schemas/entities/lead.schema.json",
      "schemas/entities/customer.schema.json",
      "schemas/entities/service.schema.json",
      "schemas/entities/workflow.schema.json",
      "schemas/entities/decision.schema.json",
      "schemas/entities/task.schema.json",
      "schemas/events/approval_requested.schema.json",
      "schemas/events/approval_decided.schema.json",
      "schemas/events/workflow_completed.schema.json",
      "schemas/events/business_policy_violation.schema.json",
      "schemas/entities/opportunity.schema.json",
      "schemas/entities/campaign.schema.json",
      "schemas/entities/ticket.schema.json"
    ],
    "approval_gate": "required-for-high-risk-actions"
  },
  "memory_policy": {
    "retention": "session+artifact",
    "pii": "minimize-and-redact"
  },
  "token_budget": {
    "max_input_tokens": 12000,
    "max_output_tokens": 2500,
    "reserve_reasoning_tokens": 1500
  },
  "context_loading": {
    "strategy": "progressive-disclosure",
    "order": [
      "required_context",
      "optional_context"
    ],
    "max_chunks": 24
  },
  "governance_level": "L2",
  "human_approval_required": true,
  "execution_mode": "semi-autonomous",
  "latency_target": "p95<=8s",
  "cost_target": "<$0.08/run",
  "determinism_level": "medium",
  "telemetry_events": [
    "skill_invoked",
    "policy_gate_checked",
    "risk_scored",
    "approval_requested",
    "output_emitted"
  ],
  "eval_metrics": [
    "schema_compliance_rate",
    "policy_gate_invocation_rate",
    "groundedness_score",
    "fallback_recovery_rate"
  ],
  "security_classification": "internal-confidential",
  "integration_targets": [
    "crm",
    "erp",
    "data-warehouse"
  ],
  "data_contracts": [
    "core/canonical-entity-model/README.md",
    "core/business-event-model/README.md",
    "schemas/entities/lead.schema.json",
    "schemas/entities/customer.schema.json",
    "schemas/entities/service.schema.json",
    "schemas/entities/workflow.schema.json",
    "schemas/entities/decision.schema.json",
    "schemas/entities/task.schema.json",
    "schemas/events/approval_requested.schema.json",
    "schemas/events/approval_decided.schema.json",
    "schemas/events/workflow_completed.schema.json",
    "schemas/events/business_policy_violation.schema.json",
    "schemas/entities/opportunity.schema.json",
    "schemas/entities/campaign.schema.json",
    "schemas/entities/ticket.schema.json"
  ],
  "failure_modes": [
    "missing_required_context",
    "schema_validation_failure",
    "policy_gate_denied",
    "upstream_connector_timeout"
  ],
  "fallbacks": [
    "emit_safe_summary",
    "request_human_approval",
    "defer_with_retry_ticket"
  ],
  "approval_controls": {
    "required_for_outbound_customer_communication": true,
    "required_for_external_mutations": true,
    "mutation_examples": [
      "create",
      "update",
      "delete",
      "send"
    ],
    "policy_permitted_bypass": "allowed only when policy profile explicitly grants outbound communication automation for lifecycle messaging",
    "enforce_consent_suppression_preferences": true
  },
  "name": "sales-marketing-customer-phase-pack",
  "subdomain": "go-to-market",
  "activation_triggers": [
    "phase_107",
    "phase_108",
    "phase_109",
    "sales_marketing_customer_phase_pack"
  ],
  "canonical_schema_refs": {
    "entities": [
      "schemas/entities/lead.schema.json",
      "schemas/entities/customer.schema.json",
      "schemas/entities/service.schema.json",
      "schemas/entities/workflow.schema.json",
      "schemas/entities/decision.schema.json",
      "schemas/entities/task.schema.json",
      "schemas/entities/opportunity.schema.json",
      "schemas/entities/campaign.schema.json",
      "schemas/entities/ticket.schema.json"
    ],
    "events": [
      "schemas/events/approval_requested.schema.json",
      "schemas/events/approval_decided.schema.json",
      "schemas/events/workflow_completed.schema.json",
      "schemas/events/business_policy_violation.schema.json"
    ]
  },
  "lifecycle_taxonomy": [
    "anonymous",
    "known_lead",
    "mql",
    "sql",
    "opportunity_open",
    "opportunity_closed_won",
    "opportunity_closed_lost",
    "onboarding",
    "active",
    "at_risk",
    "renewed",
    "churned"
  ]
}
