{
  "type": "skill",
  "version": "9.0.0",
  "owner": "Apotheon",
  "maturity": "beta",
  "dependencies": [
    "core/master-data-management",
    "core/policy-engine",
    "core/audit-trail"
  ],
  "required_context": [
    "tenant_profile",
    "canonical_entities",
    "policy_profile",
    "approval_thresholds"
  ],
  "optional_context": [
    "historical_events",
    "benchmark_data",
    "obligation_register",
    "kpi_baselines"
  ],
  "governance_level": "L2",
  "human_approval_required": true,
  "execution_mode": "support-only",
  "compliance_messaging": [
    "support-only",
    "no-final-determination",
    "human-review-required"
  ],
  "approval_policy": {
    "threshold_field": "impact_score",
    "auto_block_if_gte": 80,
    "mandatory_review_if_gte": 60
  },
  "obligation_tracking": {
    "required": true,
    "fields": [
      "obligation_id",
      "owner",
      "due_date",
      "status",
      "evidence_link"
    ]
  },
  "kpi_recommendation_policy": {
    "link_to_baseline": true,
    "require_metric_owner": true,
    "forbid_unattributed_targets": true
  },
  "high_impact_markers": {
    "mandatory_review": true,
    "required_fields": [
      "review_owner",
      "review_due_by",
      "impact_scope"
    ]
  },
  "bias_guardrails": {
    "enabled": true,
    "require_human_sensitive_review": true,
    "protected_attributes": [
      "age",
      "race",
      "sex",
      "disability",
      "religion"
    ]
  },
  "name": "legal-obligation-management-support",
  "domain": "business-operations",
  "subdomain": "phase-115",
  "activation_triggers": [
    "phase_115",
    "legal_obligation_management"
  ],
  "expert_review_boundaries": {
    "required": true,
    "review_domains": [
      "legal",
      "compliance"
    ],
    "required_reviewers": [
      "licensed_counsel"
    ],
    "prohibited_actions_without_review": [
      "final_determination",
      "external_filing",
      "policy_override"
    ]
  }
}
