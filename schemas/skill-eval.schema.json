{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill Evaluation Spec",
  "type": "object",
  "required": [
    "skill_name",
    "priority",
    "owner",
    "last_updated",
    "datasets",
    "metrics",
    "acceptance_gates"
  ],
  "properties": {
    "skill_name": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "priority": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
    "owner": {"type": "string"},
    "last_updated": {"type": "string", "format": "date"},
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "target", "direction"],
        "properties": {
          "name": {"type": "string"},
          "target": {"type": ["number", "string"]},
          "direction": {"type": "string", "enum": ["gte", "lte", "eq"]}
        }
      }
    },
    "acceptance_gates": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
