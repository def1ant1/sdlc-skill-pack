{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.dev/schemas/business-policy.schema.json",
  "title": "Business Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "name",
    "version",
    "status",
    "scope",
    "rules",
    "enforcement"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "retired"
      ]
    },
    "scope": {
      "type": "object",
      "properties": {
        "entities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "entities",
        "events"
      ],
      "additionalProperties": false
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "condition",
          "action"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "condition": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "allow",
              "block",
              "require_approval",
              "emit_violation"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "enforcement": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "advisory",
            "enforced"
          ]
        },
        "owner": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
