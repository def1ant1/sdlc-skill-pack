{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.ai/schemas/skill-metadata.schema.json",
  "title": "Skill Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "owner",
    "maturity",
    "domain",
    "token_budget",
    "governance",
    "load_modes"
  ],
  "properties": {
    "name": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "owner": {"type": "string", "minLength": 1},
    "maturity": {"type": "string", "enum": ["foundation", "alpha", "beta", "stable"]},
    "domain": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "dependencies": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "token_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "budget_strategy"],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 1},
        "output_tokens": {"type": "integer", "minimum": 1},
        "budget_strategy": {"type": "string", "enum": ["fixed", "adaptive", "tiered"]},
        "context_window_tokens": {"type": "integer", "minimum": 1}
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_refs", "risk_tier", "requires_hitl"],
      "properties": {
        "policy_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "risk_tier": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
        "requires_hitl": {"type": "boolean"},
        "data_classification": {"type": "string", "enum": ["public", "internal", "confidential", "restricted"]}
      }
    },
    "load_modes": {
      "type": "array",
      "items": {"type": "string", "enum": ["metadata_only", "runtime"]},
      "minItems": 1,
      "uniqueItems": true,
      "contains": {"const": "metadata_only"}
    }
  }
}
