{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.dev/schemas/events/approval_requested.schema.json",
  "title": "approval.requested",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "timestamp",
    "actor",
    "source_system",
    "confidence",
    "lineage",
    "policy_context",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "const": "approval.requested"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "required": [
        "actor_id",
        "actor_type"
      ],
      "properties": {
        "actor_id": {
          "type": "string"
        },
        "actor_type": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "source_system": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "lineage": {
      "type": "object",
      "required": [
        "correlation_id",
        "causation_id"
      ],
      "properties": {
        "correlation_id": {
          "type": "string"
        },
        "causation_id": {
          "type": "string"
        },
        "parent_event_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "policy_context": {
      "type": "object",
      "required": [
        "policy_id",
        "policy_version",
        "evaluation_result"
      ],
      "properties": {
        "policy_id": {
          "type": "string"
        },
        "policy_version": {
          "type": "string"
        },
        "evaluation_result": {
          "type": "string",
          "enum": [
            "pass",
            "warn",
            "fail"
          ]
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
