{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.dev/schemas/workflow-plan.schema.json",
  "title": "Workflow Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "objectives",
    "steps",
    "governance_gates",
    "dry_run_safety",
    "deterministic_artifacts",
    "planner_metadata"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "description": {"type": "string", "minLength": 1},
    "objectives": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "order", "title", "skill", "depends_on", "governance_policy_refs"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"},
          "order": {"type": "integer", "minimum": 1},
          "title": {"type": "string", "minLength": 1},
          "skill": {"type": "string", "minLength": 1},
          "depends_on": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "governance_policy_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "outputs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
        }
      }
    },
    "governance_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "policy_ref", "enforcement"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "policy_ref": {"type": "string", "minLength": 1},
          "enforcement": {"type": "string", "enum": ["advisory", "blocking"]}
        }
      }
    },
    "dry_run_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "no_external_writes", "require_human_approval_for_mutations"],
      "properties": {
        "enabled": {"type": "boolean"},
        "no_external_writes": {"type": "boolean", "const": true},
        "require_human_approval_for_mutations": {"type": "boolean", "const": true}
      }
    },
    "deterministic_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "format"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "path": {"type": "string", "pattern": "^(artifacts|reports)/.+"},
          "format": {"type": "string", "enum": ["json", "yaml", "md", "txt"]}
        }
      }
    },
    "planner_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planner", "version", "created_at"],
      "properties": {
        "planner": {"type": "string", "minLength": 1},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "created_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
