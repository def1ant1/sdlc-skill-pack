{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.local/schemas/company-template.schema.json",
  "title": "Company Template",
  "type": "object",
  "required": [
    "template_id",
    "version",
    "display_name",
    "workflows",
    "schedules",
    "dashboards",
    "connectors",
    "approvals",
    "budgets",
    "sample_data"
  ],
  "properties": {
    "template_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "display_name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "workflows": {
      "type": "object",
      "required": ["short_term", "long_term", "catalog"],
      "properties": {
        "short_term": {"$ref": "#/$defs/workflowRefs"},
        "long_term": {"$ref": "#/$defs/workflowRefs"},
        "catalog": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "schedules": {"type": "array", "items": {"type": "object"}},
    "dashboards": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "connectors": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "approvals": {"type": "array", "items": {"type": "object"}},
    "budgets": {"type": "array", "items": {"type": "object"}},
    "sample_data": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "workflowRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "plan_path"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "plan_path": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
