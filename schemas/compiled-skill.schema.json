{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.ai/schemas/compiled-skill.schema.json",
  "title": "CompiledSkill",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill_name",
    "compiler_version",
    "activity_stub",
    "eval_stub",
    "package_metadata"
  ],
  "properties": {
    "skill_name": {"type": "string", "minLength": 1},
    "compiler_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "activity_stub": {"type": "string"},
    "eval_stub": {"type": "string"},
    "package_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"}
      }
    },
    "governance": {"type": "object"},
    "telemetry": {"type": "object"}
  }
}
