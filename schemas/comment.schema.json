{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Artifact Comment",
  "type": "object",
  "required": [
    "id",
    "artifact_id",
    "author_id",
    "body",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string"
    },
    "timeline_event_id": {
      "type": "string"
    },
    "author_id": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
