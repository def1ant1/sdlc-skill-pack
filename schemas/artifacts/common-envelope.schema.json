{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.local/schemas/artifacts/common-envelope.schema.json",
  "title": "Artifact Common Envelope",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "status",
    "source",
    "owner",
    "version",
    "content",
    "links"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "type": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["draft", "active", "approved", "rejected", "archived", "completed"]},
    "source": {
      "type": "object",
      "required": ["conversation_id", "message_ids"],
      "properties": {
        "conversation_id": {"type": "string", "minLength": 1},
        "message_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "owner": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "content": {"type": "object"},
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rel", "target"],
        "properties": {
          "rel": {"type": "string"},
          "target": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
