{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "entity_type",
    "version",
    "status",
    "created_at",
    "updated_at",
    "source_system",
    "tenant_id",
    "canonical_keys",
    "links"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Canonical entity identifier (e.g., mkp_..., lst_..., inv_...)."
    },
    "entity_type": {
      "const": "shipment_tracking"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_system": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "canonical_keys": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "global_id",
        "channel_id",
        "external_ids"
      ],
      "properties": {
        "global_id": {
          "type": "string"
        },
        "channel_id": {
          "type": "string"
        },
        "sku": {
          "type": "string"
        },
        "asin": {
          "type": "string"
        },
        "upc": {
          "type": "string"
        },
        "ean": {
          "type": "string"
        },
        "isbn": {
          "type": "string"
        },
        "mpn": {
          "type": "string"
        },
        "external_ids": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "system",
              "id"
            ],
            "properties": {
              "system": {
                "type": "string"
              },
              "id": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "attributes": {
      "type": "object",
      "additionalProperties": true
    },
    "carrier": {
      "type": "string"
    },
    "tracking_number": {
      "type": "string"
    },
    "tracking_url": {
      "type": "string",
      "format": "uri"
    },
    "current_status": {
      "type": "string"
    },
    "last_event_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$id": "https://apotheon.dev/schemas/entities/shipment-tracking.schema.json",
  "title": "Shipment Tracking Entity"
}
