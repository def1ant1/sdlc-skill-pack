{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.dev/schemas/entities/customer.schema.json",
  "title": "Customer Entity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "entity_type",
    "version",
    "status",
    "created_at",
    "updated_at",
    "source_system"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique identifier."
    },
    "entity_type": {
      "const": "customer"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_system": {
      "type": "string"
    },
    "attributes": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
