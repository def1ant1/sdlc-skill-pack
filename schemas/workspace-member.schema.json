{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workspace Member",
  "type": "object",
  "required": [
    "user_id",
    "role",
    "workspace_id"
  ],
  "properties": {
    "user_id": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
