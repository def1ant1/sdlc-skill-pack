{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Schedule Run Record",
  "type": "object",
  "required": ["run_key", "schedule_id", "run_at", "executed_at", "status"],
  "properties": {
    "run_key": {"type": "string"},
    "schedule_id": {"type": "string"},
    "run_at": {"type": "string", "format": "date-time"},
    "executed_at": {"type": "string", "format": "date-time"},
    "status": {"enum": ["completed", "duplicate_skipped", "skipped"]}
  }
}
