{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.local/schemas/memory-event.schema.json",
  "title": "Memory Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "memory_layer", "content", "observed_at", "entity_refs"],
  "properties": {
    "event_id": {"type": "string", "minLength": 1},
    "workflow_id": {"type": "string"},
    "memory_layer": {"type": "string", "enum": ["episodic", "semantic", "organizational", "procedural"]},
    "content": {"type": "string", "minLength": 1},
    "observed_at": {"type": "string", "format": "date-time"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "stable_fact": {"type": "boolean"},
    "skill_improvement": {"type": "boolean"},
    "entity_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entity_type", "entity_id"],
        "properties": {
          "entity_type": {
            "type": "string",
            "enum": ["customer", "invoice", "product", "vendor", "decision", "risk", "workflow"]
          },
          "entity_id": {"type": "string"}
        }
      }
    },
    "metadata": {"type": "object"}
  }
}
