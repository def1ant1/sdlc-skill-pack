{
  "$id": "https://apotheon.dev/schemas/conversation-intent.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conversation Intent",
  "type": "object",
  "required": ["intent", "confidence", "rationale"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "answer_only",
        "brainstorm",
        "draft_plan",
        "create_task",
        "create_schedule",
        "curate_knowledge",
        "create_skill",
        "create_workflow",
        "run_workflow",
        "ask_clarifying_question"
      ]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "rationale": {"type": "string", "minLength": 1},
    "message_excerpt": {"type": "string"}
  },
  "additionalProperties": true
}
