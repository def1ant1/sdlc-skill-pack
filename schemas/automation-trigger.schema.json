{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Automation Trigger",
  "type": "object",
  "required": ["trigger_id", "name", "event_type", "workflow_plan", "dry_run"],
  "properties": {
    "trigger_id": {"type": "string", "pattern": "^[A-Za-z0-9_.:-]+$"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "event_type": {"type": "string", "minLength": 1},
    "workflow_plan": {"type": "string", "minLength": 1},
    "dry_run": {"type": "boolean"},
    "enabled": {"type": "boolean", "default": true},
    "governance": {
      "type": "object",
      "required": ["requested_actions", "autonomous_mode"],
      "properties": {
        "requested_actions": {"type": "array", "items": {"type": "string"}},
        "autonomous_mode": {"type": "boolean"}
      }
    }
  },
  "additionalProperties": true
}
