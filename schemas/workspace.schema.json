{
  "$id": "https://apotheon.dev/schemas/workspace.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workspace",
  "type": "object",
  "required": ["workspace_id", "name", "created_at", "updated_at"],
  "properties": {
    "workspace_id": {"type": "string"},
    "name": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "active_conversation_id": {"type": ["string", "null"]},
    "conversation_ids": {"type": "array", "items": {"type": "string"}},
    "artifact_ids": {"type": "array", "items": {"type": "string"}},
    "approval_ids": {"type": "array", "items": {"type": "string"}},
    "execution_run_ids": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
