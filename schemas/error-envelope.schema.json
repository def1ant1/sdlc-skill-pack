{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.local/schemas/error-envelope.schema.json",
  "title": "Error Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "error_id",
    "correlation_id",
    "workflow_run_id",
    "schedule_run_id",
    "skill",
    "step",
    "severity",
    "category",
    "retryable",
    "user_action_required",
    "message",
    "technical_detail",
    "root_cause_hint",
    "remediation",
    "source_exception",
    "created_at"
  ],
  "properties": {
    "error_id": {
      "type": "string",
      "pattern": "^err-[a-f0-9]{8}$"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_run_id": {
      "type": "string",
      "minLength": 1
    },
    "schedule_run_id": {
      "type": "string",
      "minLength": 1
    },
    "skill": {
      "type": "string",
      "minLength": 1
    },
    "step": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ]
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "retryable": {
      "type": "boolean"
    },
    "user_action_required": {
      "type": "boolean"
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "technical_detail": {
      "type": "string"
    },
    "root_cause_hint": {
      "type": "string"
    },
    "remediation": {
      "type": "string",
      "minLength": 1
    },
    "source_exception": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
