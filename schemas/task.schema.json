{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apotheon.local/schemas/task.schema.json",
  "title": "Task",
  "type": "object",
  "required": ["task_id", "title", "origin", "source_ref", "status", "acceptance_criteria", "assignee"],
  "properties": {
    "task_id": {"type": "string", "minLength": 3},
    "title": {"type": "string", "minLength": 1},
    "origin": {"type": "string", "enum": ["conversation", "plan", "workflow", "skill-gap"]},
    "source_ref": {"type": "string", "minLength": 1},
    "dependencies": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "status": {"type": "string", "enum": ["open", "in_progress", "blocked", "done", "archived"]},
    "assignee": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {"type": "string", "enum": ["user", "role", "queue", "unassigned"]},
        "id": {"type": "string"}
      },
      "allOf": [
        {"if": {"properties": {"type": {"const": "unassigned"}}}, "then": {"not": {"required": ["id"]}}},
        {"if": {"properties": {"type": {"enum": ["user", "role", "queue"]}}}, "then": {"required": ["id"]}}
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
