{
  "$id": "https://apotheon.dev/schemas/conversation-state.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conversation State",
  "type": "object",
  "required": [
    "active_goal",
    "intent",
    "intent_confidence",
    "workflow_stage",
    "completed_steps",
    "pending_steps",
    "execution_status",
    "clarification_status",
    "memory_summary",
    "turn_count",
    "rolling_memory_history",
    "plan_preview",
    "plan_deltas"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "session_id": {
      "type": "string"
    },
    "user_message": {
      "type": "string"
    },
    "active_goal": {
      "type": "string"
    },
    "intent": {
      "type": "string"
    },
    "intent_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "workflow_stage": {
      "type": "string"
    },
    "completed_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pending_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "execution_status": {
      "type": "string"
    },
    "memory_summary": {
      "type": "string"
    },
    "turn_count": {
      "type": "integer",
      "minimum": 0
    },
    "rolling_memory_turn_interval": {
      "type": "integer",
      "minimum": 1
    },
    "rolling_memory_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "turn",
          "summary"
        ],
        "properties": {
          "turn": {
            "type": "integer",
            "minimum": 1
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "plan_preview": {
      "type": "object",
      "required": [
        "current_objective",
        "planned_steps",
        "next_action"
      ],
      "properties": {
        "current_objective": {
          "type": "string"
        },
        "planned_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_action": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "plan_confirmation": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "chips": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "plan_deltas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "turn",
          "chip",
          "delta_type"
        ],
        "properties": {
          "turn": {
            "type": "integer",
            "minimum": 1
          },
          "chip": {
            "type": "string"
          },
          "instruction": {
            "type": "string"
          },
          "delta_type": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "facts": {
      "type": "object",
      "additionalProperties": true
    },
    "assumptions_catalog": {
      "type": "object",
      "additionalProperties": true
    },
    "clarifying_questions_asked": {
      "type": "integer",
      "minimum": 0
    },
    "use_best_assumptions": {
      "type": "boolean"
    },
    "policy": {
      "type": "object",
      "properties": {
        "high_risk": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "clarification_status": {
      "type": "string",
      "enum": [
        "not_started",
        "asked",
        "answered",
        "skipped"
      ]
    }
  },
  "additionalProperties": true
}
