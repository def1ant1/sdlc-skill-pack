{
  "$id": "https://apotheon.dev/schemas/conversation-state.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conversation State",
  "type": "object",
  "required": [
    "active_goal",
    "intent",
    "intent_confidence",
    "workflow_stage",
    "completed_steps",
    "pending_steps",
    "execution_status",
    "clarification_resolved",
    "memory_summary"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "updated_at": {"type": "string", "format": "date-time"},
    "session_id": {"type": "string"},
    "user_message": {"type": "string"},
    "active_goal": {"type": "string"},
    "intent": {"type": "string"},
    "intent_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "workflow_stage": {"type": "string"},
    "completed_steps": {"type": "array", "items": {"type": "string"}},
    "pending_steps": {"type": "array", "items": {"type": "string"}},
    "execution_status": {"type": "string"},
    "clarification_resolved": {"type": "boolean"},
    "memory_summary": {"type": "string"},
    "facts": {"type": "object", "additionalProperties": true},
    "assumptions_catalog": {"type": "object", "additionalProperties": true},
    "clarifying_questions_asked": {"type": "integer", "minimum": 0},
    "use_best_assumptions": {"type": "boolean"},
    "policy": {
      "type": "object",
      "properties": {
        "high_risk": {"type": "boolean"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
